# ─────────────────────────────────────────────────────────────────────────────
# ShadowGrid — Environment Variables
# Copy this file to .env and fill in the keys for your chosen providers.
# Every section is independent — only configure what you need.
# ─────────────────────────────────────────────────────────────────────────────


# ════════════════════════════════════════════════════════════════════════════
# 🌍  MAP PROVIDER  (3D globe tiles)
# ════════════════════════════════════════════════════════════════════════════
# Choose one:  cesium | google | maptiler
#
#   cesium    ✅ Recommended default. 100% free, no credit card.
#             World terrain + Bing satellite imagery + OSM 3D building
#             footprints globally.
#             Sign up: https://ion.cesium.com
#
#   google    Best visuals — photogrammetric city models from aerial imagery.
#             Requires Google Cloud billing account (free $200/mo credit
#             is sufficient for typical dev usage).
#             Sign up: https://console.cloud.google.com
#
#   maptiler  100% free tier, no credit card. Quantized-mesh terrain +
#             MapTiler satellite imagery.
#             Sign up: https://cloud.maptiler.com
#
VITE_MAP_PROVIDER=cesium

# Cesium ion (required for VITE_MAP_PROVIDER=cesium)
# Also recommended for all setups — suppresses ion console warnings.
# 1. https://ion.cesium.com → free account
# 2. Access Tokens → Create token (default scopes are fine)
VITE_CESIUM_ION_TOKEN=

# Google Maps Platform (only for VITE_MAP_PROVIDER=google)
# 1. https://console.cloud.google.com → enable "Map Tiles API"
# 2. Credentials → Create API Key → restrict to "Map Tiles API"
VITE_GOOGLE_MAPS_API_KEY=

# MapTiler (only for VITE_MAP_PROVIDER=maptiler)
# 1. https://cloud.maptiler.com → free account
# 2. Account → API Keys → copy default key
VITE_MAPTILER_API_KEY=


# ════════════════════════════════════════════════════════════════════════════
# ✈️  FLIGHT DATA PROVIDER  (live aircraft positions)
# ════════════════════════════════════════════════════════════════════════════
# Choose one:  airplaneslive | adsbool | opensky
#
#   airplaneslive  ✅ Recommended default. Completely free, no account, no key.
#                  Global unfiltered ADS-B + MLAT data. No rate limit for
#                  reasonable use.
#                  https://airplanes.live
#
#   adsbool        Free, no account, no key. ODbL-licensed open data.
#                  ADS-B Exchange drop-in replacement. Unfiltered — includes
#                  military and untracked flights.
#                  https://adsb.lol
#
#   opensky        Free for non-commercial use. Requires a free account +
#                  OAuth2 API client credentials (not just username/password —
#                  see setup steps below). 4000 credits/day authenticated.
#                  https://opensky-network.org
#
VITE_FLIGHT_PROVIDER=adsbool

# OpenSky Network credentials (only for VITE_FLIGHT_PROVIDER=opensky)
# ⚠️  OpenSky migrated to OAuth2 in March 2025. Username/password no longer work.
# Setup:
#   1. https://opensky-network.org → create free account
#   2. Account page → "API Client" section → Create API Client
#   3. Download credentials.json — copy client_id and client_secret below
VITE_OPENSKY_CLIENT_ID=
VITE_OPENSKY_CLIENT_SECRET=


# ════════════════════════════════════════════════════════════════════════════
# 🛰️  SATELLITE TLE PROVIDER  (orbital element data)
# ════════════════════════════════════════════════════════════════════════════
# Choose one:  celestrak | spacetrack | n2yo
#
#   celestrak   ✅ Recommended default. Completely free, no account, no key.
#               Provides TLEs for 20,000+ objects. The de-facto standard
#               for open satellite tracking data.
#               ⚠️  Note: transitioning to OMM format for objects > cat# 69,999
#               (expected ~July 2026). This app uses the stable GP endpoint.
#               https://celestrak.org
#
#   spacetrack  Free account required. Authoritative US Space Force data
#               (18th Space Defense Squadron). More complete than CelesTrak
#               for newly launched objects. No API key — uses login session.
#               https://space-track.org
#
#   n2yo        Free tier: 1000 requests/hour. Requires API key.
#               Good for targeted satellite lookups.
#               https://n2yo.com/api/
#
VITE_SATELLITE_PROVIDER=celestrak

# Space-Track.org credentials (only for VITE_SATELLITE_PROVIDER=spacetrack)
# 1. https://www.space-track.org → Register for free account
# 2. Add your login credentials below
VITE_SPACETRACK_USERNAME=
VITE_SPACETRACK_PASSWORD=

# N2YO API key (only for VITE_SATELLITE_PROVIDER=n2yo)
# 1. https://www.n2yo.com/api/ → request free API key
VITE_N2YO_API_KEY=


# ════════════════════════════════════════════════════════════════════════════
# 🗺️  DEFAULT STARTUP LOCATION
# ════════════════════════════════════════════════════════════════════════════
# Camera opens here on launch. Lon/Lat in decimal degrees, Alt in metres.
VITE_DEFAULT_LON=-97.7431
VITE_DEFAULT_LAT=30.2672
VITE_DEFAULT_ALT=150000

# Whether to override the above with the user's IP-derived location on startup.
#   true  — fetch ipapi.co on load and fly to the user's approximate location
#           (falls back to the coordinates above if the lookup fails)
#   false — always open at the exact lon/lat/alt set above
VITE_DEFAULT_USE_IP_LOCATION=true


# ════════════════════════════════════════════════════════════════════════════
# 🚗  STREET TRAFFIC PROVIDER
# ════════════════════════════════════════════════════════════════════════════
# Choose one: auto | google | osm
#
#   auto    Use Google live traffic when VITE_GOOGLE_MAPS_API_KEY is set,
#           otherwise fallback to OSM simulated flow.
#   google  Force Google Routes traffic-aware flow (falls back if unavailable).
#   osm     Force OSM simulated flow.
VITE_TRAFFIC_PROVIDER=auto
