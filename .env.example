# ─────────────────────────────────────────────────
# WorldView — Environment Variables
# Copy this file to .env and fill in your keys.
# ─────────────────────────────────────────────────

# Google Maps Platform — needed for Photorealistic 3D Tiles
# Enable "Map Tiles API" in your Google Cloud Console
# https://console.cloud.google.com/apis/library/tile.googleapis.com
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# OpenSky Network (optional — increases rate limits)
# Free account at https://opensky-network.org/
VITE_OPENSKY_USERNAME=
VITE_OPENSKY_PASSWORD=

# ADS-B Exchange (optional — military flight tracking)
# https://www.adsbexchange.com/data/
VITE_ADSB_EXCHANGE_API_KEY=

# Default startup location [lon, lat, altitude in meters]
VITE_DEFAULT_LON=-97.7431
VITE_DEFAULT_LAT=30.2672
VITE_DEFAULT_ALT=150000
